# ─── DentiaCore Root Environment ────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env files with actual secrets to version control.

MONGODB_URI=mongodb://localhost:27017/DentiaCore
PORT=5002
HOST=0.0.0.0
CLIENT_URL=http://localhost:5173

# Google OAuth (server-side only — never expose CLIENT_SECRET to frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5002/api/google/oauth2callback
