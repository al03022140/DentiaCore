# ─── DentiaCore Server Environment ──────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env files with actual secrets to version control.

NODE_ENV=development
API_URL=http://localhost:5002
LOG_LEVEL=info
UPLOADS_DIR=uploads

# JWT — Generate a strong random secret (≥64 hex chars):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=dentia-core
COOKIE_SECURE=false

# Google OAuth (server-side only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5002/api/google/oauth2callback

# Optional encryption key for sensitive data at rest
ENCRYPTION_KEY=

PORT=5002
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/DentiaCore
CLIENT_URL=http://localhost:5173
PUBLIC_URL=http://localhost:5002
